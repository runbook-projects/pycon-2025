<section id="register" class="section register-section">
  <div class="container">
    <h2 class="section-title">Register for PyCon 2025</h2>
    <div class="register-content">
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Early Bird</h3>
          <div class="price">$299</div>
          <p class="price-note">Until March 1, 2025</p>
          <ul class="features">
            <li>✓ Full conference access</li>
            <li>✓ All workshops & tutorials</li>
            <li>✓ Conference materials</li>
            <li>✓ Networking events</li>
            <li>✓ Lunch & refreshments</li>
          </ul>
          <button class="btn btn-primary">Register Now</button>
        </div>
        <div class="pricing-card featured">
          <div class="badge">Most Popular</div>
          <h3>Regular</h3>
          <div class="price">$399</div>
          <p class="price-note">Until April 30, 2025</p>
          <ul class="features">
            <li>✓ Full conference access</li>
            <li>✓ All workshops & tutorials</li>
            <li>✓ Conference materials</li>
            <li>✓ Networking events</li>
            <li>✓ Lunch & refreshments</li>
          </ul>
          <button class="btn btn-primary">Register Now</button>
        </div>
        <div class="pricing-card">
          <h3>Student</h3>
          <div class="price">$149</div>
          <p class="price-note">Valid student ID required</p>
          <ul class="features">
            <li>✓ Full conference access</li>
            <li>✓ All workshops & tutorials</li>
            <li>✓ Conference materials</li>
            <li>✓ Networking events</li>
            <li>✓ Lunch & refreshments</li>
          </ul>
          <button class="btn btn-primary">Register Now</button>
        </div>
      </div>
      <div class="register-info">
        <p class="info-text">
          <strong>Note:</strong> Registration includes access to all conference sessions, workshops, and social events. 
          Group discounts available for teams of 5 or more.
        </p>
      </div>
    </div>
  </div>
</section>
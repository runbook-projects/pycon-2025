---

<section id="schedule" class="section schedule-section">
  <div class="container">
    <h2 class="section-title">Conference Schedule</h2>
    <div class="schedule-content">
      <div class="schedule-day">
        <h3 class="day-title">Day 1 - May 15, 2025</h3>
        <div class="schedule-items">
          <div class="schedule-item">
            <span class="time">09:00 - 10:00</span>
            <div class="item-content">
              <h4>Opening Keynote</h4>
              <p>Welcome address and vision for Python's future</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">10:30 - 12:00</span>
            <div class="item-content">
              <h4>Morning Talks</h4>
              <p>Parallel sessions on web frameworks, async programming, and testing</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">13:00 - 14:30</span>
            <div class="item-content">
              <h4>Afternoon Workshops</h4>
              <p>Hands-on tutorials: Django, FastAPI, and Data Analysis with Pandas</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">15:00 - 17:00</span>
            <div class="item-content">
              <h4>Lightning Talks & Networking</h4>
              <p>Quick presentations and community meetups</p>
            </div>
          </div>
        </div>
      </div>
      <div class="schedule-day">
        <h3 class="day-title">Day 2 - May 16, 2025</h3>
        <div class="schedule-items">
          <div class="schedule-item">
            <span class="time">09:00 - 10:00</span>
            <div class="item-content">
              <h4>Keynote: AI & Machine Learning</h4>
              <p>The role of Python in modern AI development</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">10:30 - 12:00</span>
            <div class="item-content">
              <h4>Technical Sessions</h4>
              <p>Deep dives into performance optimization and security</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">13:00 - 16:00</span>
            <div class="item-content">
              <h4>Open Source Sprints</h4>
              <p>Contribute to Python projects with core maintainers</p>
            </div>
          </div>
          <div class="schedule-item">
            <span class="time">16:30 - 17:30</span>
            <div class="item-content">
              <h4>Closing Ceremony</h4>
              <p>Wrap-up and announcements for PyCon 2026</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
---
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>PyCon 2025</h3>
        <p>The annual Python programming conference bringing together developers from around the world.</p>
      </div>
      <div class="footer-section">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="#about">About</a></li>
          <li><a href="#schedule">Schedule</a></li>
          <li><a href="#venue">Venue</a></li>
          <li><a href="#register">Register</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Connect</h4>
        <ul>
          <li><a href="https://twitter.com/pycon" target="_blank" rel="noopener noreferrer">Twitter</a></li>
          <li><a href="https://github.com/runbook-projects/pycon-2025" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="mailto:info@pycon2025.org">Email</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Contact</h4>
        <p>
          Email: info@pycon2025.org<br>
          Phone: +1 (555) 123-4567
        </p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} PyCon 2025. All rights reserved.</p>
    </div>
  </div>
</footer>
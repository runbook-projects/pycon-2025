---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'PyCon 2025 - The annual Python programming conference' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | PyCon 2025</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --color-primary: #3776ab;
        --color-secondary: #ffd43b;
        --color-dark: #1a1a1a;
        --color-light: #f5f5f5;
        --color-text: #333;
        --color-border: #ddd;
        --spacing-xs: 0.5rem;
        --spacing-sm: 1rem;
        --spacing-md: 1.5rem;
        --spacing-lg: 2rem;
        --spacing-xl: 3rem;
        --spacing-2xl: 4rem;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        --font-mono: 'Courier New', monospace;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background-color: #fff;
        line-height: 1.6;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color 0.3s ease;
      }

      a:hover {
        color: var(--color-secondary);
      }

      button {
        font-family: var(--font-sans);
        cursor: pointer;
        border: none;
        border-radius: 0.5rem;
        padding: var(--spacing-sm) var(--spacing-md);
        font-size: 1rem;
        transition: all 0.3s ease;
      }

      button.primary {
        background-color: var(--color-primary);
        color: white;
      }

      button.primary:hover {
        background-color: #2c5aa0;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(55, 118, 171, 0.3);
      }

      h1, h2, h3, h4, h5, h6 {
        line-height: 1.2;
        margin-bottom: var(--spacing-md);
      }

      h1 {
        font-size: 3rem;
      }

      h2 {
        font-size: 2.25rem;
      }

      h3 {
        font-size: 1.75rem;
      }

      p {
        margin-bottom: var(--spacing-md);
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 var(--spacing-md);
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 2rem;
        }

        h2 {
          font-size: 1.5rem;
        }

        h3 {
          font-size: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <nav class="navbar">
        <div class="container nav-content">
          <a href="/pycon-2025/" class="logo">
            <span class="logo-text">PyCon 2025</span>
          </a>
          <ul class="nav-links">
            <li><a href="/pycon-2025/#about">About</a></li>
            <li><a href="/pycon-2025/#schedule">Schedule</a></li>
            <li><a href="/pycon-2025/#venue">Venue</a></li>
            <li><a href="/pycon-2025/#register">Register</a></li>
          </ul>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>&copy; 2025 PyCon. All rights reserved.</p>
        <p>The annual Python programming conference</p>
      </div>
    </footer>

    <style>
      header {
        background-color: var(--color-primary);
        color: white;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .navbar {
        padding: var(--spacing-md) 0;
      }

      .nav-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: bold;
        color: white;
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
      }

      .logo:hover {
        color: var(--color-secondary);
      }

      .logo-text {
        background: linear-gradient(135deg, #fff 0%, var(--color-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .nav-links {
        display: flex;
        list-style: none;
        gap: var(--spacing-lg);
      }

      .nav-links a {
        color: white;
        font-weight: 500;
        transition: color 0.3s ease;
      }

      .nav-links a:hover {
        color: var(--color-secondary);
      }

      footer {
        background-color: var(--color-dark);
        color: white;
        padding: var(--spacing-2xl) 0;
        margin-top: var(--spacing-2xl);
        text-align: center;
      }

      footer p {
        margin-bottom: var(--spacing-sm);
      }

      @media (max-width: 768px) {
        .nav-links {
          gap: var(--spacing-md);
          font-size: 0.9rem;
        }

        .logo-text {
          font-size: 1.2rem;
        }
      }
    </style>
  </body>
</html>
---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'PyCon 2025 - Annual Python Conference' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | PyCon 2025</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --color-primary: #3776ab;
        --color-secondary: #ffd43b;
        --color-dark: #1a1a1a;
        --color-light: #f5f5f5;
        --color-text: #333;
        --color-border: #ddd;
        --spacing-xs: 0.5rem;
        --spacing-sm: 1rem;
        --spacing-md: 1.5rem;
        --spacing-lg: 2rem;
        --spacing-xl: 3rem;
        --spacing-2xl: 4rem;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        --font-mono: 'Courier New', monospace;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background-color: #fff;
        line-height: 1.6;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color 0.3s ease;
      }

      a:hover {
        color: var(--color-secondary);
      }

      h1, h2, h3, h4, h5, h6 {
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: var(--spacing-md);
      }

      h1 {
        font-size: 2.5rem;
      }

      h2 {
        font-size: 2rem;
      }

      h3 {
        font-size: 1.5rem;
      }

      p {
        margin-bottom: var(--spacing-md);
      }

      button {
        font-family: var(--font-sans);
        cursor: pointer;
        border: none;
        border-radius: 0.5rem;
        padding: var(--spacing-sm) var(--spacing-lg);
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
      }

      .btn-primary {
        background-color: var(--color-primary);
        color: white;
      }

      .btn-primary:hover {
        background-color: #2c5aa0;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(55, 118, 171, 0.3);
      }

      .btn-secondary {
        background-color: var(--color-secondary);
        color: var(--color-dark);
      }

      .btn-secondary:hover {
        background-color: #ffc700;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 212, 59, 0.3);
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 var(--spacing-md);
      }

      header {
        background-color: var(--color-primary);
        color: white;
        padding: var(--spacing-md) 0;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      header nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      header .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
      }

      header nav ul {
        display: flex;
        list-style: none;
        gap: var(--spacing-lg);
      }

      header nav a {
        color: white;
        transition: color 0.3s ease;
      }

      header nav a:hover {
        color: var(--color-secondary);
      }

      footer {
        background-color: var(--color-dark);
        color: white;
        padding: var(--spacing-2xl) 0;
        margin-top: var(--spacing-2xl);
      }

      footer .container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: var(--spacing-lg);
      }

      footer h4 {
        color: var(--color-secondary);
      }

      footer ul {
        list-style: none;
      }

      footer ul li {
        margin-bottom: var(--spacing-sm);
      }

      footer a {
        color: #ccc;
      }

      footer a:hover {
        color: var(--color-secondary);
      }

      .footer-bottom {
        text-align: center;
        margin-top: var(--spacing-2xl);
        padding-top: var(--spacing-lg);
        border-top: 1px solid #444;
        color: #999;
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 2rem;
        }

        h2 {
          font-size: 1.5rem;
        }

        h3 {
          font-size: 1.25rem;
        }

        header nav ul {
          gap: var(--spacing-md);
          font-size: 0.9rem;
        }
      }

      @media (max-width: 480px) {
        header nav ul {
          flex-direction: column;
          gap: var(--spacing-sm);
        }

        h1 {
          font-size: 1.5rem;
        }

        h2 {
          font-size: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <div class="logo">🐍 PyCon 2025</div>
          <ul>
            <li><a href="/pycon-2025/">Home</a></li>
            <li><a href="/pycon-2025/#about">About</a></li>
            <li><a href="/pycon-2025/#schedule">Schedule</a></li>
            <li><a href="/pycon-2025/#venue">Venue</a></li>
            <li><a href="/pycon-2025/#register">Register</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div>
          <h4>About PyCon 2025</h4>
          <p>The premier annual conference for the Python community, bringing together developers, data scientists, and enthusiasts worldwide.</p>
        </div>
        <div>
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/pycon-2025/">Home</a></li>
            <li><a href="/pycon-2025/#schedule">Schedule</a></li>
            <li><a href="/pycon-2025/#venue">Venue</a></li>
            <li><a href="/pycon-2025/#register">Register</a></li>
          </ul>
        </div>
        <div>
          <h4>Connect</h4>
          <ul>
            <li><a href="#">Twitter</a></li>
            <li><a href="#">GitHub</a></li>
            <li><a href="#">Discord</a></li>
            <li><a href="#">Email</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2025 PyCon. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
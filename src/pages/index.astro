---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>PyCon 2025</h1>
      <p class="tagline">The Annual Python Programming Conference</p>
      <p class="description">Join thousands of Python developers, data scientists, and enthusiasts for three days of talks, workshops, and networking.</p>
      <button class="primary cta-button">Register Now</button>
    </div>
    <div class="hero-image">
      <img src="/pycon-2025/assets/event-image-1.png" alt="PyCon 2025 Event Banner" />
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section about">
    <div class="container">
      <h2>About PyCon 2025</h2>
      <div class="about-grid">
        <div class="about-card">
          <h3>🎯 Mission</h3>
          <p>PyCon is the premier conference for the Python community. We bring together developers, educators, and enthusiasts to share knowledge, collaborate, and advance the Python ecosystem.</p>
        </div>
        <div class="about-card">
          <h3>🌍 Community</h3>
          <p>With attendees from over 50 countries, PyCon is a global celebration of Python. Network with peers, learn from experts, and be part of a vibrant community.</p>
        </div>
        <div class="about-card">
          <h3>📚 Learning</h3>
          <p>Discover cutting-edge topics including web development, data science, machine learning, DevOps, and more. Choose from hundreds of talks and workshops.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule Section -->
  <section id="schedule" class="section schedule">
    <div class="container">
      <h2>Conference Schedule</h2>
      <div class="schedule-grid">
        <div class="schedule-card">
          <div class="day-badge">Day 1</div>
          <h3>Keynotes & Opening</h3>
          <p><strong>Date:</strong> May 16, 2025</p>
          <p>Join us for inspiring keynote presentations from industry leaders and the official conference opening ceremony.</p>
        </div>
        <div class="schedule-card">
          <div class="day-badge">Day 2</div>
          <h3>Talks & Workshops</h3>
          <p><strong>Date:</strong> May 17, 2025</p>
          <p>Attend parallel tracks featuring talks on web development, data science, DevOps, and emerging Python technologies.</p>
        </div>
        <div class="schedule-card">
          <div class="day-badge">Day 3</div>
          <h3>Sprints & Closing</h3>
          <p><strong>Date:</strong> May 18, 2025</p>
          <p>Participate in open-source sprints, networking sessions, and the closing ceremony with announcements for next year.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Venue Section -->
  <section id="venue" class="section venue">
    <div class="container">
      <h2>Venue Information</h2>
      <div class="venue-content">
        <div class="venue-details">
          <h3>Location</h3>
          <p><strong>Convention Center</strong></p>
          <p>123 Tech Boulevard<br />San Francisco, CA 94105<br />United States</p>
          
          <h3 style="margin-top: var(--spacing-lg);">Getting There</h3>
          <ul class="venue-list">
            <li>🚗 Ample parking available on-site</li>
            <li>🚌 Public transportation: BART and Muni nearby</li>
            <li>✈️ Close to SFO and Oakland airports</li>
            <li>🏨 Hotel accommodations available at discounted rates</li>
          </ul>
        </div>
        <div class="venue-map">
          <div class="map-placeholder">
            <p>📍 Map Coming Soon</p>
            <p>Interactive venue map will be available here</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Register Section -->
  <section id="register" class="section register">
    <div class="container">
      <h2>Register for PyCon 2025</h2>
      <div class="register-content">
        <div class="ticket-card">
          <h3>Early Bird</h3>
          <p class="price">$299</p>
          <ul class="ticket-features">
            <li>✓ 3-day conference pass</li>
            <li>✓ All talks and workshops</li>
            <li>✓ Lunch and refreshments</li>
            <li>✓ Conference t-shirt</li>
          </ul>
          <button class="primary">Get Early Bird Ticket</button>
        </div>
        <div class="ticket-card featured">
          <h3>Standard</h3>
          <p class="price">$399</p>
          <ul class="ticket-features">
            <li>✓ 3-day conference pass</li>
            <li>✓ All talks and workshops</li>
            <li>✓ Lunch and refreshments</li>
            <li>✓ Conference t-shirt</li>
            <li>✓ Networking events</li>
          </ul>
          <button class="primary">Get Standard Ticket</button>
        </div>
        <div class="ticket-card">
          <h3>Student</h3>
          <p class="price">$99</p>
          <ul class="ticket-features">
            <li>✓ 3-day conference pass</li>
            <li>✓ All talks and workshops</li>
            <li>✓ Lunch and refreshments</li>
            <li>✓ Conference t-shirt</li>
          </ul>
          <button class="primary">Get Student Ticket</button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
    padding: var(--spacing-2xl) 0;
    background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
    color: white;
  }

  .hero-content {
    padding: var(--spacing-2xl);
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: var(--spacing-md);
    color: white;
  }

  .tagline {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-secondary);
    font-weight: 600;
  }

  .description {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-lg);
    line-height: 1.8;
  }

  .cta-button {
    font-size: 1.1rem;
    padding: var(--spacing-md) var(--spacing-lg);
    background-color: var(--color-secondary);
    color: var(--color-primary);
    font-weight: bold;
  }

  .cta-button:hover {
    background-color: #ffe680;
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(255, 212, 59, 0.4);
  }

  .hero-image {
    position: relative;
    height: 400px;
    overflow: hidden;
    border-radius: 1rem;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section {
    padding: var(--spacing-2xl) 0;
  }

  .about {
    background-color: var(--color-light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
  }

  .about-card {
    background: white;
    padding: var(--spacing-lg);
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .about-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .about-card h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
  }

  .schedule-card {
    background: white;
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    padding: var(--spacing-lg);
    position: relative;
    transition: all 0.3s ease;
  }

  .schedule-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(55, 118, 171, 0.2);
  }

  .day-badge {
    display: inline-block;
    background-color: var(--color-primary);
    color: white;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: bold;
    margin-bottom: var(--spacing-md);
  }

  .schedule-card h3 {
    color: var(--color-primary);
  }

  .venue {
    background-color: var(--color-light);
  }

  .venue-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    margin-top: var(--spacing-lg);
    align-items: start;
  }

  .venue-details {
    background: white;
    padding: var(--spacing-lg);
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .venue-details h3 {
    color: var(--color-primary);
  }

  .venue-list {
    list-style: none;
    padding: 0;
  }

  .venue-list li {
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .venue-list li:last-child {
    border-bottom: none;
  }

  .map-placeholder {
    background: linear-gradient(135deg, #e8f0f7 0%, #f0e8f7 100%);
    border-radius: 0.75rem;
    padding: var(--spacing-2xl);
    text-align: center;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--color-primary);
  }

  .map-placeholder p {
    margin: 0;
  }

  .register {
    background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
    color: white;
  }

  .register h2 {
    color: white;
  }

  .register-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
  }

  .ticket-card {
    background: white;
    color: var(--color-text);
    padding: var(--spacing-lg);
    border-radius: 0.75rem;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ticket-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
  }

  .ticket-card.featured {
    border: 3px solid var(--color-secondary);
    transform: scale(1.05);
  }

  .ticket-card h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .price {
    font-size: 2.5rem;
    font-weight: bold;
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .ticket-features {
    list-style: none;
    text-align: left;
    margin-bottom: var(--spacing-lg);
  }

  .ticket-features li {
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .ticket-features li:last-child {
    border-bottom: none;
  }

  .ticket-card button {
    width: 100%;
    background-color: var(--color-primary);
    color: white;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      padding: var(--spacing-lg) 0;
    }

    .hero h1 {
      font-size: 2.5rem;
    }

    .tagline {
      font-size: 1.2rem;
    }

    .hero-image {
      height: 250px;
    }

    .venue-content {
      grid-template-columns: 1fr;
    }

    .ticket-card.featured {
      transform: scale(1);
    }
  }
</style>
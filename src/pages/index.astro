---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <h1>PyCon 2025</h1>
      <p class="hero-subtitle">The Annual Python Programming Conference</p>
      <p class="hero-description">Join thousands of Python developers, data scientists, and enthusiasts for three days of talks, workshops, and networking.</p>
      <button class="cta-button">Register Now</button>
    </div>
    <div class="hero-image">
      <img src="/pycon-2025/assets/event-image-1.png" alt="PyCon 2025 Event Banner" />
    </div>
  </section>

  <section id="about" class="section about">
    <div class="container">
      <h2>About PyCon 2025</h2>
      <div class="about-grid">
        <div class="about-card">
          <h3>Learn & Grow</h3>
          <p>Discover the latest trends, best practices, and innovations in the Python ecosystem. Attend talks from industry experts and thought leaders.</p>
        </div>
        <div class="about-card">
          <h3>Network & Connect</h3>
          <p>Meet fellow Python developers, collaborate on projects, and build lasting relationships with the global Python community.</p>
        </div>
        <div class="about-card">
          <h3>Hands-On Workshops</h3>
          <p>Participate in interactive workshops covering web development, data science, machine learning, and more.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="schedule" class="section schedule">
    <div class="container">
      <h2>Schedule Highlights</h2>
      <div class="schedule-grid">
        <div class="schedule-card">
          <h3>Day 1: Keynotes & Tutorials</h3>
          <p><strong>May 15, 2025</strong></p>
          <p>Opening keynote followed by hands-on tutorials covering Python fundamentals and advanced topics.</p>
        </div>
        <div class="schedule-card">
          <h3>Day 2: Technical Talks</h3>
          <p><strong>May 16, 2025</strong></p>
          <p>Deep-dive sessions on web frameworks, data science, DevOps, and emerging technologies in the Python ecosystem.</p>
        </div>
        <div class="schedule-card">
          <h3>Day 3: Workshops & Closing</h3>
          <p><strong>May 17, 2025</strong></p>
          <p>Specialized workshops, lightning talks, and closing keynote with community highlights.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="venue" class="section venue">
    <div class="container">
      <h2>Venue Information</h2>
      <div class="venue-content">
        <div class="venue-details">
          <h3>Convention Center</h3>
          <p><strong>Location:</strong> Downtown Convention Center</p>
          <p><strong>Address:</strong> 123 Main Street, Tech City, TC 12345</p>
          <p><strong>Dates:</strong> May 15-17, 2025</p>
          <p><strong>Hours:</strong> 8:00 AM - 6:00 PM (Daily)</p>
          <p>Easy access via public transportation. Parking available on-site. Accessible facilities for all attendees.</p>
        </div>
        <div class="venue-map">
          <div class="map-placeholder">
            <p>📍 Map Coming Soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="register" class="section register">
    <div class="container register-container">
      <h2>Register for PyCon 2025</h2>
      <p>Secure your spot at the premier Python conference. Early bird tickets available now!</p>
      <div class="ticket-options">
        <div class="ticket-card">
          <h3>Standard Pass</h3>
          <p class="price">$299</p>
          <ul class="ticket-features">
            <li>✓ All 3 days of talks</li>
            <li>✓ Workshop access</li>
            <li>✓ Lunch & refreshments</li>
            <li>✓ Networking events</li>
          </ul>
          <button>Get Standard Pass</button>
        </div>
        <div class="ticket-card featured">
          <h3>Premium Pass</h3>
          <p class="price">$499</p>
          <ul class="ticket-features">
            <li>✓ All Standard features</li>
            <li>✓ VIP seating</li>
            <li>✓ Meet & greet with speakers</li>
            <li>✓ Exclusive merchandise</li>
          </ul>
          <button>Get Premium Pass</button>
        </div>
        <div class="ticket-card">
          <h3>Student Pass</h3>
          <p class="price">$99</p>
          <ul class="ticket-features">
            <li>✓ All 3 days of talks</li>
            <li>✓ Workshop access</li>
            <li>✓ Lunch & refreshments</li>
            <li>✓ Student networking</li>
          </ul>
          <button>Get Student Pass</button>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero {
      background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
      color: white;
      padding: var(--spacing-2xl) 0;
      display: flex;
      align-items: center;
      gap: var(--spacing-2xl);
    }

    .hero .container {
      display: flex;
      align-items: center;
      gap: var(--spacing-2xl);
      width: 100%;
    }

    .hero-content {
      flex: 1;
      min-width: 0;
    }

    .hero h1 {
      font-size: 4rem;
      margin-bottom: var(--spacing-md);
      color: #ffd43b;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
    }

    .hero-subtitle {
      font-size: 1.5rem;
      margin-bottom: var(--spacing-md);
      color: #fff;
    }

    .hero-description {
      font-size: 1.125rem;
      margin-bottom: var(--spacing-lg);
      color: rgba(255, 255, 255, 0.95);
    }

    .cta-button {
      background-color: #ffd43b;
      color: #3776ab;
      font-weight: 700;
      font-size: 1.125rem;
      padding: var(--spacing-md) var(--spacing-xl);
      border-radius: 0.5rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .cta-button:hover {
      background-color: #fff;
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
    }

    .hero-image {
      flex: 1;
      min-width: 0;
    }

    .hero-image img {
      width: 100%;
      height: auto;
      border-radius: 0.5rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .section {
      padding: var(--spacing-2xl) 0;
    }

    .about {
      background-color: var(--color-light);
    }

    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-lg);
      margin-top: var(--spacing-lg);
    }

    .about-card {
      background: white;
      padding: var(--spacing-lg);
      border-radius: 0.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .about-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    }

    .about-card h3 {
      color: var(--color-primary);
    }

    .schedule {
      background-color: white;
    }

    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-lg);
      margin-top: var(--spacing-lg);
    }

    .schedule-card {
      background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
      padding: var(--spacing-lg);
      border-radius: 0.5rem;
      border-left: 4px solid var(--color-primary);
      transition: all 0.3s ease;
    }

    .schedule-card:hover {
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
      transform: translateX(4px);
    }

    .schedule-card h3 {
      color: var(--color-primary);
    }

    .venue {
      background-color: var(--color-light);
    }

    .venue-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-2xl);
      margin-top: var(--spacing-lg);
      align-items: center;
    }

    .venue-details {
      background: white;
      padding: var(--spacing-lg);
      border-radius: 0.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .venue-details h3 {
      color: var(--color-primary);
    }

    .venue-details p {
      margin-bottom: var(--spacing-sm);
    }

    .map-placeholder {
      background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
      height: 300px;
      border-radius: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 1.5rem;
      font-weight: 600;
    }

    .register {
      background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
      color: white;
    }

    .register-container {
      text-align: center;
    }

    .register h2 {
      color: #ffd43b;
    }

    .register > .container > p {
      font-size: 1.125rem;
      margin-bottom: var(--spacing-lg);
    }

    .ticket-options {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--spacing-lg);
      margin-top: var(--spacing-2xl);
    }

    .ticket-card {
      background: white;
      color: var(--color-text);
      padding: var(--spacing-lg);
      border-radius: 0.5rem;
      text-align: center;
      transition: all 0.3s ease;
      border: 2px solid transparent;
    }

    .ticket-card.featured {
      transform: scale(1.05);
      border-color: #ffd43b;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .ticket-card:hover {
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .ticket-card h3 {
      color: var(--color-primary);
      margin-bottom: var(--spacing-md);
    }

    .price {
      font-size: 2.5rem;
      font-weight: 700;
      color: #ffd43b;
      margin-bottom: var(--spacing-md);
    }

    .ticket-features {
      list-style: none;
      margin-bottom: var(--spacing-lg);
      text-align: left;
    }

    .ticket-features li {
      padding: var(--spacing-xs) 0;
      margin-bottom: var(--spacing-xs);
    }

    .ticket-card button {
      width: 100%;
      background-color: var(--color-primary);
      color: white;
    }

    .ticket-card button:hover {
      background-color: #2c5aa0;
    }

    @media (max-width: 1024px) {
      .hero {
        padding: var(--spacing-xl) 0;
      }

      .hero .container {
        flex-direction: column;
      }

      .hero h1 {
        font-size: 3rem;
      }

      .venue-content {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .hero {
        padding: var(--spacing-lg) 0;
      }

      .hero h1 {
        font-size: 2.5rem;
      }

      .hero-subtitle {
        font-size: 1.25rem;
      }

      .hero-description {
        font-size: 1rem;
      }

      .section {
        padding: var(--spacing-lg) 0;
      }

      .ticket-card.featured {
        transform: scale(1);
      }
    }
  </style>
</Layout>
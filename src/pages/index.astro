---
import Layout from '../layouts/Layout.astro';
---

<Layout title="PyCon 2025 - Annual Python Conference">
  <style>
    /* Hero Section */
    .hero {
      position: relative;
      height: 500px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #ffffff;
      text-align: center;
      overflow: hidden;
      margin: 2rem 0;
      border-radius: 8px;
    }

    .hero-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.4;
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 2rem;
    }

    .hero h1 {
      font-size: 3.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .hero p {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
    }

    .cta-button {
      display: inline-block;
      background-color: #3b82f6;
      color: #ffffff;
      padding: 1rem 2rem;
      border-radius: 4px;
      font-size: 1.1rem;
      font-weight: 600;
      transition: background-color 0.3s ease, transform 0.2s ease;
      text-decoration: none;
    }

    .cta-button:hover {
      background-color: #1e40af;
      transform: translateY(-2px);
    }

    /* Section Styles */
    section {
      margin: 4rem 0;
      padding: 2rem 0;
      border-bottom: 1px solid #e5e7eb;
    }

    section:last-child {
      border-bottom: none;
    }

    h2 {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
      color: #1a1a1a;
    }

    h3 {
      font-size: 1.5rem;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      color: #374151;
    }

    p {
      margin-bottom: 1rem;
      color: #4b5563;
      line-height: 1.8;
    }

    /* About Section */
    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .about-card {
      background-color: #f9fafb;
      padding: 1.5rem;
      border-radius: 8px;
      border-left: 4px solid #667eea;
    }

    .about-card h3 {
      margin-top: 0;
    }

    /* Schedule Section */
    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .schedule-card {
      background-color: #f0f4ff;
      padding: 1.5rem;
      border-radius: 8px;
      border-top: 4px solid #667eea;
    }

    .schedule-card h4 {
      color: #667eea;
      margin-bottom: 0.5rem;
    }

    .time {
      font-size: 0.9rem;
      color: #6b7280;
      font-weight: 500;
    }

    /* Venue Section */
    .venue-info {
      background-color: #f9fafb;
      padding: 2rem;
      border-radius: 8px;
      margin-top: 2rem;
    }

    .venue-info p {
      margin-bottom: 0.75rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero {
        height: 350px;
        margin: 1rem 0;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .hero p {
        font-size: 1.1rem;
      }

      h2 {
        font-size: 1.75rem;
      }

      .about-grid,
      .schedule-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <!-- Hero Section -->
  <section class="hero" aria-label="Hero section">
    <img
      src="/pycon-2025/assets/event-image-1.png"
      alt="PyCon 2025 Conference"
      class="hero-image"
    />
    <div class="hero-content">
      <h1>PyCon 2025</h1>
      <p>Annual Python Conference</p>
      <a href="#register" class="cta-button">Register Now</a>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" aria-labelledby="about-heading">
    <h2 id="about-heading">About PyCon 2025</h2>
    <p>
      PyCon 2025 is the premier annual conference bringing together Python developers from around the world.
      Join us for three days of inspiring talks, hands-on workshops, and networking opportunities with the
      global Python community.
    </p>

    <div class="about-grid">
      <div class="about-card">
        <h3>Expert Speakers</h3>
        <p>
          Learn from leading Python developers and industry experts sharing their knowledge and experience.
        </p>
      </div>
      <div class="about-card">
        <h3>Hands-On Workshops</h3>
        <p>
          Participate in interactive workshops covering the latest Python frameworks, tools, and best practices.
        </p>
      </div>
      <div class="about-card">
        <h3>Networking</h3>
        <p>
          Connect with fellow developers, share ideas, and build lasting relationships with the Python community.
        </p>
      </div>
    </div>
  </section>

  <!-- Schedule Section -->
  <section id="schedule" aria-labelledby="schedule-heading">
    <h2 id="schedule-heading">Conference Schedule</h2>
    <p>Three days of talks, workshops, and community engagement.</p>

    <div class="schedule-grid">
      <div class="schedule-card">
        <h4>Day 1: Opening & Keynotes</h4>
        <p class="time">Monday, June 2, 2025</p>
        <p>
          Welcome to PyCon 2025! Start with opening remarks and keynote presentations from industry leaders.
        </p>
      </div>
      <div class="schedule-card">
        <h4>Day 2: Workshops & Talks</h4>
        <p class="time">Tuesday, June 3, 2025</p>
        <p>
          Dive deep into technical talks and hands-on workshops covering web development, data science, and more.
        </p>
      </div>
      <div class="schedule-card">
        <h4>Day 3: Advanced Topics & Closing</h4>
        <p class="time">Wednesday, June 4, 2025</p>
        <p>
          Explore advanced topics, lightning talks, and closing remarks celebrating the Python community.
        </p>
      </div>
    </div>
  </section>

  <!-- Venue Section -->
  <section id="venue" aria-labelledby="venue-heading">
    <h2 id="venue-heading">Venue Information</h2>
    <div class="venue-info">
      <h3>Conference Location</h3>
      <p><strong>Convention Center</strong></p>
      <p>123 Developer Street</p>
      <p>Tech City, TC 12345</p>
      <p>United States</p>

      <h3 style="margin-top: 1.5rem;">Getting There</h3>
      <p>
        The venue is easily accessible by public transportation. Free parking is available for registered attendees.
        Detailed directions and transportation information will be provided upon registration.
      </p>
    </div>
  </section>

  <!-- Registration Section -->
  <section id="register" aria-labelledby="register-heading">
    <h2 id="register-heading">Register for PyCon 2025</h2>
    <p>
      Secure your spot at PyCon 2025 today! Early bird tickets are available at a special rate for a limited time.
    </p>
    <div style="margin-top: 2rem;">
      <button class="cta-button" onclick="alert('Registration form would open here')">Get Your Ticket</button>
    </div>
  </section>
</Layout>

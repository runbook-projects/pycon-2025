---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <style>
    .hero {
      background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
      color: white;
      padding: 4rem 0;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: url('/pycon-2025/assets/event-image-1.png');
      background-size: cover;
      background-position: center;
      opacity: 0.15;
      z-index: 0;
    }

    .hero .container {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-content h1 {
      font-size: 3.5rem;
      margin-bottom: 1rem;
      color: white;
    }

    .hero-content p {
      font-size: 1.25rem;
      margin-bottom: 2rem;
      color: #ffd43b;
    }

    .hero-content .description {
      font-size: 1.1rem;
      margin-bottom: 2rem;
      color: rgba(255, 255, 255, 0.95);
      line-height: 1.8;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .hero-image {
      position: relative;
      z-index: 1;
    }

    .hero-image img {
      width: 100%;
      height: auto;
      border-radius: 0.5rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }

    .section {
      padding: 4rem 0;
      border-bottom: 1px solid #eee;
    }

    .section:last-of-type {
      border-bottom: none;
    }

    .section h2 {
      color: #3776ab;
      margin-bottom: 2rem;
      text-align: center;
    }

    .about-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .about-card {
      background: #f9f9f9;
      padding: 2rem;
      border-radius: 0.5rem;
      border-left: 4px solid #3776ab;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .about-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    .about-card h3 {
      color: #3776ab;
      margin-bottom: 1rem;
    }

    .schedule-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .schedule-card {
      background: white;
      border: 2px solid #3776ab;
      border-radius: 0.5rem;
      padding: 2rem;
      transition: all 0.3s ease;
    }

    .schedule-card:hover {
      box-shadow: 0 8px 20px rgba(55, 118, 171, 0.2);
      border-color: #ffd43b;
    }

    .schedule-card .day {
      font-weight: 700;
      color: #3776ab;
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
    }

    .schedule-card .time {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .schedule-card p {
      margin-bottom: 0;
    }

    .venue-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
      margin-top: 2rem;
    }

    .venue-info h3 {
      color: #3776ab;
      margin-bottom: 1rem;
    }

    .venue-info p {
      margin-bottom: 1rem;
    }

    .venue-map {
      background: #f0f0f0;
      border-radius: 0.5rem;
      padding: 2rem;
      text-align: center;
      color: #999;
      min-height: 300px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px dashed #ddd;
    }

    .register-section {
      background: linear-gradient(135deg, #3776ab 0%, #2c5aa0 100%);
      color: white;
      padding: 4rem 2rem;
      border-radius: 0.5rem;
      text-align: center;
      margin-top: 2rem;
    }

    .register-section h3 {
      color: white;
      margin-bottom: 1rem;
    }

    .register-section p {
      font-size: 1.1rem;
      margin-bottom: 2rem;
      color: rgba(255, 255, 255, 0.95);
    }

    .register-button {
      background-color: #ffd43b;
      color: #3776ab;
      font-weight: 700;
      font-size: 1.1rem;
      padding: 1rem 2rem;
    }

    .register-button:hover {
      background-color: #ffc700;
    }

    @media (max-width: 768px) {
      .hero .container {
        grid-template-columns: 1fr;
      }

      .hero-content h1 {
        font-size: 2.5rem;
      }

      .venue-content {
        grid-template-columns: 1fr;
      }

      .section {
        padding: 2rem 0;
      }
    }
  </style>

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>PyCon 2025</h1>
        <p>The Premier Python Conference</p>
        <p class="description">Annual Python conference bringing together developers, data scientists, and enthusiasts for talks, workshops, and networking.</p>
        <div class="hero-buttons">
          <button class="btn-primary" onclick="document.getElementById('register').scrollIntoView({behavior: 'smooth'})">Register Now</button>
          <button class="btn-secondary" onclick="document.getElementById('schedule').scrollIntoView({behavior: 'smooth'})">View Schedule</button>
        </div>
      </div>
      <div class="hero-image">
        <img src="/pycon-2025/assets/event-image-1.png" alt="PyCon 2025 Event Banner" />
      </div>
    </div>
  </section>

  <section id="about" class="section">
    <div class="container">
      <h2>About PyCon 2025</h2>
      <p style="text-align: center; font-size: 1.1rem; color: #666; margin-bottom: 2rem;">
        Join the global Python community for three days of inspiring talks, hands-on workshops, and meaningful connections.
      </p>
      <div class="about-grid">
        <div class="about-card">
          <h3>🎤 Keynote Speakers</h3>
          <p>Learn from industry leaders and open-source pioneers sharing insights on the latest Python trends and best practices.</p>
        </div>
        <div class="about-card">
          <h3>🛠️ Hands-On Workshops</h3>
          <p>Participate in interactive workshops covering web development, data science, machine learning, and more.</p>
        </div>
        <div class="about-card">
          <h3>🤝 Networking</h3>
          <p>Connect with thousands of Python developers, share ideas, and build lasting professional relationships.</p>
        </div>
        <div class="about-card">
          <h3>💡 Innovation Showcase</h3>
          <p>Discover cutting-edge projects and tools from the Python ecosystem and emerging startups.</p>
        </div>
        <div class="about-card">
          <h3>🎓 Learning Tracks</h3>
          <p>Choose from multiple tracks tailored to your experience level, from beginner to advanced topics.</p>
        </div>
        <div class="about-card">
          <h3>🌍 Global Community</h3>
          <p>Be part of a diverse, inclusive community celebrating Python and its impact worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="schedule" class="section">
    <div class="container">
      <h2>Conference Schedule</h2>
      <div class="schedule-grid">
        <div class="schedule-card">
          <div class="day">Day 1: May 16</div>
          <div class="time">9:00 AM - 5:00 PM</div>
          <p><strong>Opening Keynote & Talks</strong></p>
          <p>Welcome address followed by inspiring talks from industry leaders on Python's future.</p>
        </div>
        <div class="schedule-card">
          <div class="day">Day 2: May 17</div>
          <div class="time">9:00 AM - 5:00 PM</div>
          <p><strong>Workshops & Deep Dives</strong></p>
          <p>Hands-on workshops and technical deep dives into specialized Python topics and frameworks.</p>
        </div>
        <div class="schedule-card">
          <div class="day">Day 3: May 18</div>
          <div class="time">9:00 AM - 5:00 PM</div>
          <p><strong>Lightning Talks & Closing</strong></p>
          <p>Community lightning talks, innovation showcase, and closing ceremony with networking reception.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="venue" class="section">
    <div class="container">
      <h2>Venue & Location</h2>
      <div class="venue-content">
        <div class="venue-info">
          <h3>Conference Details</h3>
          <p><strong>Location:</strong> Convention Center, Downtown</p>
          <p><strong>Dates:</strong> May 16-18, 2025</p>
          <p><strong>Time:</strong> 9:00 AM - 5:00 PM (Daily)</p>
          <p><strong>Capacity:</strong> 2,000+ attendees</p>
          <p style="margin-top: 1.5rem;">The venue is easily accessible by public transportation and offers ample parking. Complimentary breakfast, lunch, and refreshments will be provided throughout the conference.</p>
          <p>Accessibility accommodations are available. Please contact us for specific needs.</p>
        </div>
        <div class="venue-map">
          <div>
            <p style="font-size: 1.1rem; margin-bottom: 1rem;">📍 Interactive Map</p>
            <p>Map integration coming soon</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="register" class="section">
    <div class="container">
      <div class="register-section">
        <h3>Ready to Join?</h3>
        <p>Secure your spot at PyCon 2025 and be part of the world's premier Python conference.</p>
        <button class="register-button">Register for PyCon 2025</button>
        <p style="font-size: 0.9rem; margin-top: 1rem; color: rgba(255, 255, 255, 0.8);">Early bird tickets available until April 30, 2025</p>
      </div>
    </div>
  </section>
</Layout>
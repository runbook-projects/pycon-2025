---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const basePath = import.meta.env.BASE_URL || '/';
const heroImageUrl = `${basePath}assets/event-image-1.png`;
---

<Layout title="PyCon 2025 - Annual Python Conference">
  <Header />
  
  <Hero 
    title="PyCon 2025" 
    subtitle="Annual Python Conference for Developers, Data Scientists & Enthusiasts"
    imageUrl={heroImageUrl}
  />

  <Section id="about" title="About PyCon 2025" subtitle="Join the global Python community">
    <div class="about-content">
      <p>
        PyCon 2025 brings together developers, data scientists, and Python enthusiasts from around the world for an unforgettable experience. Whether you're a beginner or an expert, PyCon offers something for everyone.
      </p>
      <p>
        Attend inspiring talks from industry leaders, participate in hands-on workshops, network with fellow Pythonistas, and discover the latest trends and innovations in the Python ecosystem.
      </p>
    </div>
    <div class="features-grid">
      <Card 
        title="Expert Talks" 
        description="Learn from leading Python developers and industry experts sharing their insights and experiences."
        icon="🎤"
      />
      <Card 
        title="Hands-on Workshops" 
        description="Participate in interactive workshops covering various Python topics and frameworks."
        icon="🛠️"
      />
      <Card 
        title="Networking" 
        description="Connect with thousands of Python developers and build meaningful professional relationships."
        icon="🤝"
      />
      <Card 
        title="Community" 
        description="Be part of the vibrant global Python community and contribute to open source projects."
        icon="🌍"
      />
    </div>
  </Section>

  <Section id="schedule" title="Schedule" subtitle="Key dates and events">
    <div class="schedule-content">
      <div class="schedule-item">
        <div class="schedule-date">May 15-17, 2025</div>
        <h3>Main Conference</h3>
        <p>Three days of talks, workshops, and networking sessions featuring the best of the Python community.</p>
      </div>
      <div class="schedule-item">
        <div class="schedule-date">May 14, 2025</div>
        <h3>Tutorials Day</h3>
        <p>Pre-conference tutorials covering beginner to advanced Python topics and frameworks.</p>
      </div>
      <div class="schedule-item">
        <div class="schedule-date">May 18, 2025</div>
        <h3>Sprints</h3>
        <p>Post-conference sprints where you can contribute to open source Python projects.</p>
      </div>
    </div>
  </Section>

  <Section id="venue" title="Venue" subtitle="Where we're gathering">
    <div class="venue-content">
      <div class="venue-info">
        <h3>Convention Center</h3>
        <p><strong>Location:</strong> Downtown Convention Center</p>
        <p><strong>Address:</strong> 123 Main Street, Tech City, TC 12345</p>
        <p><strong>Capacity:</strong> 5,000+ attendees</p>
        <p>
          Our venue features state-of-the-art facilities including multiple conference halls, workshop spaces, and networking areas. Easy access to public transportation and nearby hotels.
        </p>
      </div>
      <div class="venue-amenities">
        <h3>Amenities</h3>
        <ul>
          <li>✓ Free WiFi throughout the venue</li>
          <li>✓ Complimentary breakfast and lunch</li>
          <li>✓ Accessible facilities</li>
          <li>✓ Parking available</li>
          <li>✓ Quiet spaces for breaks</li>
          <li>✓ On-site childcare available</li>
        </ul>
      </div>
    </div>
  </Section>

  <Section id="register" title="Register Now" subtitle="Secure your spot at PyCon 2025">
    <div class="register-content">
      <div class="register-card">
        <h3>Early Bird</h3>
        <div class="price">$299</div>
        <p class="price-note">Available until April 30, 2025</p>
        <ul class="features-list">
          <li>✓ 3-day conference access</li>
          <li>✓ All talks and workshops</li>
          <li>✓ Meals included</li>
          <li>✓ Conference materials</li>
        </ul>
        <Button href="#" variant="primary" size="large">Register Early Bird</Button>
      </div>
      <div class="register-card featured">
        <div class="badge">Most Popular</div>
        <h3>Standard</h3>
        <div class="price">$399</div>
        <p class="price-note">Available until May 10, 2025</p>
        <ul class="features-list">
          <li>✓ 3-day conference access</li>
          <li>✓ All talks and workshops</li>
          <li>✓ Meals included</li>
          <li>✓ Conference materials</li>
          <li>✓ T-shirt</li>
        </ul>
        <Button href="#" variant="primary" size="large">Register Standard</Button>
      </div>
      <div class="register-card">
        <h3>Student</h3>
        <div class="price">$99</div>
        <p class="price-note">With valid student ID</p>
        <ul class="features-list">
          <li>✓ 3-day conference access</li>
          <li>✓ All talks and workshops</li>
          <li>✓ Meals included</li>
          <li>✓ Conference materials</li>
        </ul>
        <Button href="#" variant="primary" size="large">Register Student</Button>
      </div>
    </div>
  </Section>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2025 PyCon. All rights reserved.</p>
      <p>Follow us on social media for updates and announcements.</p>
    </div>
  </footer>
</Layout>

<style>
  .about-content {
    max-width: 800px;
    margin: 0 auto 3rem;
    text-align: center;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .schedule-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .schedule-item {
    background: #f8f9fa;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #0066cc;
  }

  .schedule-date {
    color: #0066cc;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .venue-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .venue-info,
  .venue-amenities {
    background: #f8f9fa;
    padding: 2rem;
    border-radius: 8px;
  }

  .venue-amenities ul {
    list-style: none;
    padding: 0;
  }

  .venue-amenities li {
    padding: 0.5rem 0;
    font-size: 1.05rem;
  }

  .register-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .register-card {
    background: white;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    position: relative;
    transition: all 0.3s ease;
  }

  .register-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .register-card.featured {
    border-color: #0066cc;
    transform: scale(1.05);
  }

  .badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #0066cc;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: bold;
  }

  .price {
    font-size: 2.5rem;
    font-weight: bold;
    color: #0066cc;
    margin: 1rem 0;
  }

  .price-note {
    color: #999;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .features-list {
    list-style: none;
    text-align: left;
    margin: 1.5rem 0;
    padding: 0;
  }

  .features-list li {
    padding: 0.5rem 0;
    color: #666;
  }

  .footer {
    background: #1a1a1a;
    color: white;
    padding: 2rem 0;
    text-align: center;
  }

  .footer .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .footer p {
    margin: 0.5rem 0;
  }

  @media (max-width: 768px) {
    .venue-content {
      grid-template-columns: 1fr;
    }

    .register-card.featured {
      transform: scale(1);
    }
  }
</style>
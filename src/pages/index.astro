---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <h1>PyCon 2025</h1>
      <p class="hero-subtitle">Annual Python conference bringing together developers from around the world.</p>
      <button class="cta-button">Register Now</button>
    </div>
    <div class="hero-image">
      <img src="/pycon-2025/assets/event-image-1.png" alt="PyCon 2025 Event Banner" />
    </div>
  </section>

  <section id="about" class="section about">
    <div class="container">
      <h2>About PyCon 2025</h2>
      <p>
        PyCon 2025 is the premier annual conference for the Python programming community. Bringing together developers, data scientists, educators, and enthusiasts from around the globe, PyCon is the place to learn, connect, and celebrate the Python ecosystem.
      </p>
      <div class="features">
        <div class="feature-card">
          <h3>🎤 Keynote Speakers</h3>
          <p>Hear from industry leaders and Python pioneers sharing insights on the latest trends and innovations.</p>
        </div>
        <div class="feature-card">
          <h3>🛠️ Hands-On Workshops</h3>
          <p>Participate in interactive workshops covering everything from web development to machine learning.</p>
        </div>
        <div class="feature-card">
          <h3>🤝 Networking</h3>
          <p>Connect with fellow developers, share experiences, and build lasting professional relationships.</p>
        </div>
        <div class="feature-card">
          <h3>📚 Learning Tracks</h3>
          <p>Choose from multiple tracks tailored to your experience level and interests.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="schedule" class="section schedule">
    <div class="container">
      <h2>Schedule</h2>
      <div class="schedule-grid">
        <div class="schedule-day">
          <h3>Day 1: Monday, May 12</h3>
          <ul class="schedule-list">
            <li>
              <strong>09:00 AM - 10:00 AM</strong>
              <p>Opening Keynote: "The Future of Python"</p>
            </li>
            <li>
              <strong>10:30 AM - 12:00 PM</strong>
              <p>Workshop: Advanced Python Patterns</p>
            </li>
            <li>
              <strong>01:00 PM - 02:30 PM</strong>
              <p>Talk Track: Web Development with FastAPI</p>
            </li>
            <li>
              <strong>03:00 PM - 04:30 PM</strong>
              <p>Workshop: Data Science with Pandas</p>
            </li>
          </ul>
        </div>
        <div class="schedule-day">
          <h3>Day 2: Tuesday, May 13</h3>
          <ul class="schedule-list">
            <li>
              <strong>09:00 AM - 10:30 AM</strong>
              <p>Talk Track: Machine Learning Best Practices</p>
            </li>
            <li>
              <strong>11:00 AM - 12:30 PM</strong>
              <p>Workshop: Testing and CI/CD</p>
            </li>
            <li>
              <strong>01:30 PM - 03:00 PM</strong>
              <p>Lightning Talks</p>
            </li>
            <li>
              <strong>03:30 PM - 05:00 PM</strong>
              <p>Closing Keynote & Awards</p>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="venue" class="section venue">
    <div class="container">
      <h2>Venue</h2>
      <div class="venue-content">
        <div class="venue-info">
          <h3>Convention Center</h3>
          <p><strong>Location:</strong> San Francisco, California</p>
          <p><strong>Address:</strong> 747 Market Street, San Francisco, CA 94103</p>
          <p><strong>Dates:</strong> May 12-13, 2025</p>
          <p><strong>Time:</strong> 9:00 AM - 5:00 PM (Both Days)</p>
          <p>
            The venue is easily accessible by public transportation and offers ample parking. Complimentary breakfast, lunch, and refreshments will be provided throughout the conference.
          </p>
        </div>
        <div class="venue-map">
          <div class="map-placeholder">
            <p>📍 San Francisco Convention Center</p>
            <p>Interactive map would be displayed here</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="register" class="section register">
    <div class="container">
      <h2>Register for PyCon 2025</h2>
      <p class="register-intro">
        Secure your spot at PyCon 2025 today! Early bird tickets are available at a special rate.
      </p>
      <div class="ticket-options">
        <div class="ticket-card">
          <h3>Early Bird</h3>
          <p class="price">$199</p>
          <ul class="ticket-features">
            <li>✓ Access to all talks and workshops</li>
            <li>✓ Conference materials</li>
            <li>✓ Meals and refreshments</li>
            <li>✓ Networking events</li>
          </ul>
          <button>Get Early Bird Ticket</button>
        </div>
        <div class="ticket-card featured">
          <h3>Standard</h3>
          <p class="price">$299</p>
          <ul class="ticket-features">
            <li>✓ Access to all talks and workshops</li>
            <li>✓ Conference materials</li>
            <li>✓ Meals and refreshments</li>
            <li>✓ Networking events</li>
            <li>✓ Premium seating</li>
          </ul>
          <button>Get Standard Ticket</button>
        </div>
        <div class="ticket-card">
          <h3>Student</h3>
          <p class="price">$99</p>
          <ul class="ticket-features">
            <li>✓ Access to all talks and workshops</li>
            <li>✓ Conference materials</li>
            <li>✓ Meals and refreshments</li>
            <li>✓ Networking events</li>
          </ul>
          <button>Get Student Ticket</button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
    padding: var(--spacing-2xl) 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, #2d5f8d 100%);
    color: white;
  }

  .hero-content {
    padding: var(--spacing-2xl);
  }

  .hero h1 {
    color: white;
    margin-bottom: var(--spacing-md);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-lg);
    color: rgba(255, 255, 255, 0.95);
  }

  .cta-button {
    background-color: var(--color-secondary);
    color: var(--color-dark);
    font-weight: 700;
    padding: var(--spacing-md) var(--spacing-2xl);
    font-size: 1.1rem;
  }

  .cta-button:hover {
    background-color: #ffd43b;
    transform: translateY(-3px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
  }

  .hero-image {
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .section {
    padding: var(--spacing-2xl) 0;
  }

  .about {
    background-color: var(--color-light);
  }

  .about h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .about > .container > p {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-2xl);
    color: var(--color-text);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-lg);
  }

  .feature-card {
    background-color: white;
    padding: var(--spacing-lg);
    border-radius: 0.5rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .feature-card h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .schedule {
    background-color: white;
  }

  .schedule h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .schedule-day {
    background-color: var(--color-light);
    padding: var(--spacing-lg);
    border-radius: 0.5rem;
    border-left: 4px solid var(--color-primary);
  }

  .schedule-day h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .schedule-list {
    list-style: none;
  }

  .schedule-list li {
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
  }

  .schedule-list li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .schedule-list strong {
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--spacing-xs);
  }

  .schedule-list p {
    margin: 0;
    color: var(--color-text);
  }

  .venue {
    background-color: var(--color-light);
  }

  .venue h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .venue-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
  }

  .venue-info h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .venue-info p {
    margin-bottom: var(--spacing-md);
  }

  .map-placeholder {
    background-color: #e8e8e8;
    padding: var(--spacing-2xl);
    border-radius: 0.5rem;
    text-align: center;
    color: var(--color-text);
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .map-placeholder p {
    margin: var(--spacing-md) 0;
  }

  .register {
    background-color: white;
  }

  .register h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .register-intro {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-2xl);
    text-align: center;
  }

  .ticket-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
  }

  .ticket-card {
    background-color: var(--color-light);
    padding: var(--spacing-lg);
    border-radius: 0.5rem;
    border: 2px solid var(--color-border);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .ticket-card.featured {
    border-color: var(--color-primary);
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(55, 118, 171, 0.2);
  }

  .ticket-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ticket-card h3 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .ticket-features {
    list-style: none;
    margin-bottom: var(--spacing-lg);
    text-align: left;
  }

  .ticket-features li {
    padding: var(--spacing-xs) 0;
    color: var(--color-text);
  }

  .ticket-card button {
    width: 100%;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      padding: var(--spacing-lg) 0;
    }

    .hero-content {
      padding: var(--spacing-lg);
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .venue-content {
      grid-template-columns: 1fr;
    }

    .ticket-card.featured {
      transform: scale(1);
    }
  }
</style>